# Base de datos — Neon PostgreSQL (conseguir en neon.tech)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.us-east-1.aws.neon.tech/neondb?sslmode=require"

# JWT — generar con: openssl rand -base64 32
JWT_SECRET="cambia-esto-por-un-secreto-largo-y-seguro"

# Admin inicial (usado en el seed)
ADMIN_EMAIL="admin@neska.com"
ADMIN_PASSWORD="cambia-esta-contraseña"

# Cloudinary (conseguir en cloudinary.com — plan Free alcanza)
CLOUDINARY_CLOUD_NAME="tu-cloud-name"
CLOUDINARY_API_KEY="tu-api-key"
CLOUDINARY_API_SECRET="tu-api-secret"

# Mercado Pago (conseguir en mercadopago.com.ar/developers)
MP_ACCESS_TOKEN="APP_USR-xxxx"
MP_PUBLIC_KEY="APP_USR-xxxx"
NEXT_PUBLIC_MP_PUBLIC_KEY="APP_USR-xxxx"

# URL pública del sitio (en Vercel se completa automáticamente con VERCEL_URL)
NEXT_PUBLIC_BASE_URL="https://tu-dominio.vercel.app"
